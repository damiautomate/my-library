rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && userDoc().role == "admin";
    }

    function isMember() {
      return isSignedIn() && (userDoc().role == "member" || userDoc().role == "admin");
    }

    // USERS
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId
                                     && !("role" in request.resource.data.diff(resource.data).affectedKeys()));
      allow delete: if isAdmin();
    }

    // INVITATIONS — admin-only from the client; the /api/users/onboard route
    // uses the Admin SDK and is unaffected by these rules.
    match /invitations/{inviteId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // BOOKS — members read published only, admins read everything; admins write
    match /books/{bookId} {
      allow read: if isMember() && (resource.data.status == "published" || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    // READING PROGRESS — owner-scoped writes by document-ID prefix; admins read
    match /reading_progress/{progressId} {
      allow read, write: if isSignedIn() && progressId.matches(request.auth.uid + "_.*");
      allow read: if isAdmin();
    }
  }
}
